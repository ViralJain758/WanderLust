<% layout("/layouts/boilerplate.ejs") %>

<div class="policy-page">
  <div class="policy-container">
    <div class="policy-hero">
      <div class="policy-hero-icon">
        <i class="fa-solid fa-shield-halved"></i>
      </div>
      <h1>Privacy Policy</h1>
      <p class="policy-meta">
        Effective Date: January 1, 2025 &nbsp;·&nbsp; Last Updated: March 1,
        2026
      </p>
    </div>

    <div class="policy-toc">
      <p class="toc-label">On this page</p>
      <ol>
        <li><a href="#information-we-collect">Information We Collect</a></li>
        <li><a href="#how-we-use">How We Use Your Information</a></li>
        <li><a href="#sharing">Sharing of Information</a></li>
        <li><a href="#cookies">Cookies &amp; Tracking</a></li>
        <li><a href="#security">Data Security</a></li>
        <li><a href="#your-rights">Your Rights</a></li>
        <li><a href="#contact">Contact Us</a></li>
      </ol>
    </div>

    <div class="policy-body">
      <p class="policy-lead">
        At WanderLust, your privacy matters. This policy explains what data we
        collect, why we collect it, and how we keep it safe.
      </p>

      <section id="information-we-collect">
        <h2>
          <span class="policy-section-num">1</span> Information We Collect
        </h2>
        <p>
          We collect information you give us directly and some information
          automatically when you use our service.
        </p>
        <ul>
          <li>
            <strong>Account data</strong> — your name, email address, and
            password when you register.
          </li>
          <li>
            <strong>Listing data</strong> — details, photos, location, and
            pricing you provide when creating a listing.
          </li>
          <li>
            <strong>Usage data</strong> — pages visited, search queries, and
            feature interactions.
          </li>
          <li>
            <strong>Device data</strong> — IP address, browser type, and
            operating system, collected automatically.
          </li>
        </ul>
      </section>

      <section id="how-we-use">
        <h2>
          <span class="policy-section-num">2</span> How We Use Your Information
        </h2>
        <ul>
          <li>To create and manage your WanderLust account.</li>
          <li>
            To display listings, reviews, and maps relevant to your searches.
          </li>
          <li>To send important service and security notifications.</li>
          <li>To improve platform performance and fix bugs.</li>
          <li>To comply with our legal obligations.</li>
        </ul>
      </section>

      <section id="sharing">
        <h2>
          <span class="policy-section-num">3</span> Sharing of Information
        </h2>
        <p>
          We do <strong>not</strong> sell your personal data. We may share
          limited data with:
        </p>
        <ul>
          <li>
            <strong>Cloudinary</strong> — to store listing images you upload.
          </li>
          <li>
            <strong>Google Maps</strong> — to display location maps on listing
            pages.
          </li>
          <li>
            <strong>Law enforcement</strong> — only when required by applicable
            law.
          </li>
        </ul>
      </section>

      <section id="cookies">
        <h2>
          <span class="policy-section-num">4</span> Cookies &amp; Tracking
        </h2>
        <p>
          We use session cookies to keep you logged in and remember your
          preferences. We do not use third-party advertising cookies. You can
          disable cookies in your browser settings, but some features may stop
          working.
        </p>
      </section>

      <section id="security">
        <h2><span class="policy-section-num">5</span> Data Security</h2>
        <p>
          Passwords are hashed, sessions are encrypted, and all traffic runs
          over HTTPS. No system is 100% secure — if you suspect unauthorised
          access, please contact us immediately.
        </p>
      </section>

      <section id="your-rights">
        <h2><span class="policy-section-num">6</span> Your Rights</h2>
        <p>Depending on your location, you may have the right to:</p>
        <ul>
          <li>Access or download a copy of your personal data.</li>
          <li>Request correction of inaccurate data.</li>
          <li>Request deletion of your account and associated data.</li>
          <li>Object to certain types of processing.</li>
        </ul>
      </section>

      <section id="contact">
        <h2><span class="policy-section-num">7</span> Contact Us</h2>
        <p>
          Questions about this policy? Reach us at
          <a href="mailto:privacy@wanderlust.com">privacy@wanderlust.com</a>.
        </p>
      </section>
    </div>

    <div class="policy-footer-links">
      <a href="/terms">Terms of Service &rarr;</a>
      <a href="/listings">Browse Listings &rarr;</a>
    </div>
  </div>
</div>
